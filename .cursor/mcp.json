      "env": {
        "DB_HOST": "127.0.0.1",
        "DB_PORT": "5432",
        "DB_DATABASE": "inventario_saludambiental",
        "DB_USERNAME": "postgres",
        "DB_PASSWORD": "postgres",
        "DB_SSLMODE": "prefer"
      }
    }
  }
}
